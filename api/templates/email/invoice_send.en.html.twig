{% extends '_layout.html.twig' %}

{% block content %}
<h1 style="margin:0 0 16px;font-size:22px;font-weight:600;color:#15131D;">
  {% if is_test %}<span style="color:#E8A547;">[TEST] </span>{% endif %}{{ greeting }}
</h1>

<p style="margin:0 0 16px;">{{ intro|raw }}</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;background:#F4F2FB;border-radius:8px;margin:16px 0;">
  <tr>
    <td style="padding:16px 20px;">
      <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;font-size:14px;color:#403B52;">
        <tr>
          <td style="padding:4px 0;color:#7A748C;width:42%;">Variable symbol</td>
          <td style="padding:4px 0;font-family:monospace;font-weight:600;color:#15131D;">{{ invoice.varsymbol }}</td>
        </tr>
        <tr>
          <td style="padding:4px 0;color:#7A748C;">Issue date</td>
          <td style="padding:4px 0;">{{ invoice.issue_date|date('M j, Y') }}</td>
        </tr>
        <tr>
          <td style="padding:4px 0;color:#7A748C;">Due date</td>
          <td style="padding:4px 0;font-weight:600;">{{ invoice.due_date|date('M j, Y') }}</td>
        </tr>
        <tr>
          <td style="padding:8px 0 0;color:#7A748C;border-top:1px solid #E5E0F4;">{% if is_paid %}Paid{% else %}Amount due{% endif %}</td>
          <td style="padding:8px 0 0;border-top:1px solid #E5E0F4;font-size:18px;font-weight:700;color:{% if is_paid %}#2E7D32{% else %}#3B2D83{% endif %};font-family:monospace;">
            {{ amount_to_pay|number_format(2, '.', ',') }} {{ invoice.currency }}{% if is_paid %} ✓{% endif %}
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{% if is_paid %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:24px 0 8px;">
  <tr>
    <td style="padding:14px 18px;background:#E8F5E9;border-left:3px solid #2E7D32;border-radius:4px;font-size:14px;color:#1B5E20;">
      <strong>This invoice has been paid.</strong>
      {% if payment_method == 'card' %} Payment was made online by card — please do not pay again.
      {% elseif payment_method == 'cash' %} Payment was made in cash.
      {% else %} Please do not pay again.
      {% endif %}
    </td>
  </tr>
</table>
{% elseif payment_method == 'card' %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:24px 0 8px;">
  <tr>
    <td style="padding:14px 18px;background:#FFF8E1;border-left:3px solid #E8A547;border-radius:4px;font-size:14px;color:#5D4500;">
      <strong>Card payment.</strong> Bank transfer and QR code are not used for this invoice.
    </td>
  </tr>
</table>
{% elseif payment_method == 'cash' %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:24px 0 8px;">
  <tr>
    <td style="padding:14px 18px;background:#FFF8E1;border-left:3px solid #E8A547;border-radius:4px;font-size:14px;color:#5D4500;">
      <strong>Cash payment.</strong>
    </td>
  </tr>
</table>
{% endif %}

{% if qr_data_uri %}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin:32px 0 8px;">
  <tr>
    <td align="center">
      <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin:0 auto;">
        <tr>
          <td style="text-align:center;padding:12px;background:#fff;border:1px solid #E7E3EE;border-radius:8px;">
            <img src="{{ qr_data_uri }}" alt="QR payment" width="180" height="180" style="display:block;margin:0 auto;">
            <div style="font-size:11px;color:#7A748C;letter-spacing:1px;margin-top:6px;text-transform:uppercase;">QR payment</div>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
{% endif %}

<p style="margin:16px 0 8px;font-size:14px;color:#5A5470;">
  The invoice PDF is attached{% if qr_data_uri %}; you can pay by scanning the QR code above{% endif %}.
</p>

{% if not is_test %}
<p style="margin:24px 0 0;font-size:13px;color:#7A748C;">
  Thank you for your business.
</p>
{% endif %}

{% if is_test %}
<p style="margin:24px 0 0;padding:12px;background:#FDF6E9;border-left:2px solid #E8A547;font-size:13px;color:#8B6420;">
  <strong>This is a TEST email.</strong> The client did not receive it.
</p>
{% endif %}
{% endblock %}
